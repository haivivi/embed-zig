# Unified CI targets — compile all ESP targets + run all std tests
#
# Usage:
#   bazel build //e2e/ci:build_all_esp --config=ci
#   bazel build //e2e/ci:build_all_e2e_esp --config=ci
#   bazel build //e2e/ci:build_all_examples_esp --config=ci

load("//bazel/esp:transitions.bzl", "esp_board_build")

package(default_visibility = ["//visibility:public"])

# =============================================================================
# E2E Tests — ESP cross-compile
# =============================================================================

# --- tier0_sync: esp32s3_devkit ---
esp_board_build(name = "tier0_sync_esp32s3_devkit", target = "//e2e/tier0_sync/esp:app", board = "esp32s3_devkit")

