# Std platform — compilation check for native binaries
# (targets that build but aren't zig_test, so can't go in test_std)
filegroup(
    name = "build_all_std",
    srcs = [
        "//e2e/tier2_opus_aec/native:test",
    ],
)

# =============================================================================
# Aggregate: Test targets (std platform, auto-run in CI)
# =============================================================================

# All std tests — `bazel test //e2e/ci:test_std`
# Includes conformance tests + tier tests with std support.
test_suite(
    name = "test_std",
    tags = ["std"],
    tests = [
        # Conformance (trait verification)
        "//e2e/trait/time/std:test",
        "//e2e/trait/log/std:test",
        "//e2e/trait/sync/std:test",
        "//e2e/trait/rng/std:test",
        "//e2e/trait/socket/std:test",
        "//e2e/trait/crypto/std:test",
        "//e2e/trait/system/std:test",
        "//e2e/trait/spawner/std:test",
        "//e2e/trait/io/std:test",
        "//e2e/trait/codec/std:test",
        "//e2e/trait/rtc/std:test",
        # Tier 0 (async primitives)
        "//e2e/tier0_timer/native:test",
        # Tier 1 (network)
        "//lib/pkg/net/http/test:http_e2e_test",
    ],
)

# =============================================================================
# Aggregate: All platforms build check
# =============================================================================

# Everything — `bazel build //e2e/ci:build_all`
filegroup(
    name = "build_all",
    srcs = [
        ":build_all_esp",
        ":build_all_bk",
        ":build_all_std",
    ],
)
