# All ESP targets (e2e + examples)
filegroup(
    name = "build_all_esp",
    srcs = [
        ":build_all_e2e_esp",
        ":build_all_examples_esp",
    ],
)

# Std platform tests (run on CI without hardware)
filegroup(
    name = "test_all_std",
    srcs = [
        "//e2e/tier2_opus_aec/native:test",
    ],
)
