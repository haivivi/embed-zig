# Unified CI targets
#
# Build checks (compilation only, no execution):
#   bazel build //e2e/ci:build_all_esp
#   bazel build //e2e/ci:build_all_bk
#   bazel build //e2e/ci:build_all_std
#
# Test execution (std platform, no hardware):
#   bazel test //e2e/ci:test_std
#
# All-in-one:
#   bazel build //e2e/ci:build_all

load("//bazel/esp:transitions.bzl", "esp_board_build")

package(default_visibility = ["//visibility:public"])

