        # ":led_strip_flash_korvo2_v3",  # TODO: pre-existing board.zig error
        ":motion_test_lichuang_szp",
        ":motion_test_lichuang_gocool",
        ":ntp_test_esp32s3_devkit",
        ":ntp_test_korvo2_v3",
        ":nvs_storage_esp32s3_devkit",
