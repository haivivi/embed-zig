# =============================================================================
# Aggregate targets
# =============================================================================

# All e2e ESP targets
filegroup(
    name = "build_all_e2e_esp",
    srcs = [
        ":tier0_sync_esp32s3_devkit",
        ":tier0_memory_esp32s3_devkit",
        ":tier0_timer_esp32s3_devkit",
        ":tier1_net_event_esp32s3_devkit",
        ":tier1_tls_concurrent_esp32s3_devkit",
        ":tier1_wifi_scan_esp32s3_devkit",
        ":tier2_opus_aec_lichuang_gocool",
        ":tier3_ble_esp32s3_devkit",
        ":tier3_hci_esp32s3_devkit",
        ":benchmark_http_speed_esp32s3_devkit",
        ":benchmark_https_speed_esp32s3_devkit",
        ":benchmark_tcp_speed_esp32s3_devkit",
        ":benchmark_tls_speed_esp32s3_devkit",
        ":benchmark_ble_throughput_esp32s3_devkit",
        ":benchmark_ble_x_proto_esp32s3_devkit",
    ],
)

