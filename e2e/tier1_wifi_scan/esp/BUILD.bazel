# =============================================================================
# Test 5: Buffer Boundary
# =============================================================================

esp_zig_app(
    name = "buffer_boundary_app",
    app = ":srcs",
    entry_file = "buffer_boundary.zig",
    entry_fn = "entry",
    requires = _requires,
    force_link = _force_link,
    extra_cmake = _extra_cmake,
    extra_c_sources = _extra_c_sources,
    deps = _deps,
    sdkconfig = "//examples/esp:esp32s3_wifi_xip",
    app_config = "//examples/esp:app",
