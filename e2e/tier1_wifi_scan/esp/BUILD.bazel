# =============================================================================
# Legacy: Original all-in-one app (for backward compatibility)
# =============================================================================

esp_zig_app(
    name = "app",
    app = ":srcs",
    entry_file = "app.zig",
    entry_fn = "run",
    requires = _requires,
    force_link = _force_link,
    extra_cmake = _extra_cmake,
    extra_c_sources = _extra_c_sources,
    deps = _deps,
    sdkconfig = "//examples/esp:esp32s3_wifi_xip",
    app_config = "//examples/esp:app",
)

esp_flash(
    name = "flash",
    app = ":app",
)
