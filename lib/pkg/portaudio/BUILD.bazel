load("//bazel/zig:defs.bzl", "zig_library")

package(default_visibility = ["//visibility:public"])

# portaudio library — delegates to //third_party/portaudio which contains
# the actual blocking-mode implementation built from source via zig cc.
alias(
    name = "portaudio",
    actual = "//third_party/portaudio",
)

filegroup(name = "srcs", srcs = glob(["**/*"]))
